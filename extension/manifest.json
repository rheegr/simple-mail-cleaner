{
  "manifest_version": 3,
  "name": "Simple Mail Cleaner",
  "version": "0.2.3",
  "description": "Select an email in Gmail and unsubscribe or clean out its entire sender in one click.",
  "permissions": ["identity", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://gmail.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://*.hubspotemail.net/*",
    "https://*.list-manage.com/*",
    "https://*.substack.com/*",
    "https://*.mailchimp.com/*"
  ],
  "oauth2": {
    "client_id": "76451738783-e6torhr8g4upgnel92g49b5b1ndbjgiu.apps.googleusercontent.com",
    "scopes": ["https://mail.google.com/"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Simple Mail Cleaner"
  }
}
